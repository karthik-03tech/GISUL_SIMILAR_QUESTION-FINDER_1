# .env.example — copy to .env and fill in your values

# PostgreSQL connection string (Supabase connection pooler URL)
DATABASE_URL=

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# JWT algorithm (default: HS256)
JWT_ALGORITHM=HS256

# JWT token expiry in minutes (default: 60)
JWT_EXPIRE_MINUTES=60

# Qdrant Cloud cluster URL (e.g. https://xxxx.us-east-1-0.aws.cloud.qdrant.io)
QDRANT_URL=

# Qdrant API key from your cluster settings
QDRANT_API_KEY=

# Qdrant collection name (default: gisul_questions)
QDRANT_COLLECTION=gisul_questions

# Sentence-transformers model name (default: all-MiniLM-L6-v2)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# HuggingFace access token (from https://huggingface.co/settings/tokens)
HF_API_TOKEN=
